generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  FLEET_MANAGER
  DISPATCHER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trips       Trip[]
  maintenance Maintenance[]
}

enum VehicleType {
  VAN
  TRUCK
  BUS
  MOTORCYCLE
  PICKUP
  TRAILER
  OTHER
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

model Vehicle {
  id                 String        @id @default(cuid())
  registrationNumber String        @unique
  name               String
  model              String
  type               VehicleType
  maxLoadCapacity    Float
  odometer           Float
  acquisitionCost    Decimal
  status             VehicleStatus @default(AVAILABLE)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  trips        Trip[]
  maintenances Maintenance[]
  fuelLogs     FuelLog[]
  expenses     Expense[]

  @@index([status])
  @@index([type])
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  ON_LEAVE
  TERMINATED
}

model Driver {
  id              String       @id @default(cuid())
  name            String
  licenseNumber   String       @unique
  licenseCategory String
  licenseExpiry   DateTime
  contactNumber   String
  safetyScore     Float        @default(100)
  status          DriverStatus @default(AVAILABLE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  trips Trip[]

  @@index([status])
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

model Trip {
  id              String     @id @default(cuid())
  vehicleId       String
  driverId        String
  createdBy       String
  source          String
  destination     String
  cargoWeight     Float
  plannedDistance Float
  actualDistance  Float?
  revenue         Decimal?   @db.Decimal(12, 2)
  status          TripStatus @default(DRAFT)
  dispatchedAt    DateTime?
  completedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  driver  Driver  @relation(fields: [driverId], references: [id])
  creator User    @relation(fields: [createdBy], references: [id])

  @@index([status])
  @@index([vehicleId])
  @@index([driverId])
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CANCELLED
}

model Maintenance {
  id          String            @id @default(cuid())
  vehicleId   String
  createdById String?
  status      MaintenanceStatus @default(OPEN)
  description String?
  cost        Decimal?          @db.Decimal(12, 2)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])
  createdBy User?   @relation(fields: [createdById], references: [id])

  @@index([status])
}

enum ExpenseType {
  TOLL
  INSURANCE
  OTHER
}

model FuelLog {
  id        String   @id @default(uuid())
  liters    Float
  cost      Decimal  @db.Decimal(12, 2)
  odometer  Float
  fuelDate  DateTime
  createdAt DateTime @default(now())
  vehicleId String

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([fuelDate])
}

model Expense {
  id          String      @id @default(uuid())
  type        ExpenseType
  amount      Decimal     @db.Decimal(12, 2)
  description String?
  expenseDate DateTime
  createdAt   DateTime    @default(now())
  vehicleId   String

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([expenseDate])
}
